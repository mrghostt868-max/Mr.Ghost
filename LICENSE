  <script>
  function toggleSection(id, btn) {
    const content = document.getElementById(id);
    const arrow = btn.querySelector('.toggle-arrow');
    const isOpen = content.style.display === "block";

    const isMainCategory = btn.classList.contains('toggle-section');

    if (isMainCategory) {
      const allSections = document.querySelectorAll('.toggle-section');
      allSections.forEach(sectionBtn => {
        if (sectionBtn !== btn) {
          const sectionId = sectionBtn.getAttribute('onclick').match(/'([^']+)'/)[1];
          const otherContent = document.getElementById(sectionId);
          const otherArrow = sectionBtn.querySelector('.toggle-arrow');
          if (otherContent && otherContent.style.display === "block") {
            otherContent.style.display = "none";
            otherArrow.classList.remove("open");

            const nestedToggleContents = otherContent.querySelectorAll('.toggle-content');
            nestedToggleContents.forEach(nestedContent => {
              nestedContent.style.display = "none";
            });

            const nestedTogglePriceBtns = otherContent.querySelectorAll('.toggle-price');
            nestedTogglePriceBtns.forEach(priceBtn => {
              const priceArrow = priceBtn.querySelector('.toggle-arrow');
              if (priceArrow) priceArrow.classList.remove("open");
            });
          }
        }
      });

      content.style.display = isOpen ? "none" : "block";
      arrow.classList.toggle("open", !isOpen);

    } else {
      content.style.display = isOpen ? "none" : "block";
      arrow.classList.toggle("open", !isOpen);
    }
  }
</script>

